# frozen_string_literal: true

source "https://rubygems.org"

# Mirrors the GitHub Pages production build (Jekyll 3.10 + whitelisted
# plugins) so `bundle exec jekyll serve` previews exactly what deploys.
gem "github-pages", group: :jekyll_plugins

# Jekyll 3 on Ruby 3+ needs webrick for `jekyll serve`.
gem "webrick"
